# Configurazione client (Vite). Copiare in .env e compilare.
# NB: solo variabili NON sensibili — finiscono nel bundle del browser.
# La service role key NON va MAI qui: vive solo nella Edge Function
# admin-users (variabile SUPABASE_SERVICE_ROLE_KEY, iniettata da Supabase).

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
